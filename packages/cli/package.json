{
  "name": "npm-scanner",
  "version": "0.1.0",
  "description": "Fast, free, accurate npm dependency vulnerability scanner for local + CI/CD, powered by OSV.dev",
  "license": "MIT",
  "type": "module",
  "bin": {
    "npm-scanner": "./dist/index.js",
    "npmscan": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "security",
    "vulnerability",
    "scanner",
    "audit",
    "npm",
    "osv",
    "cve",
    "sarif",
    "ci",
    "dependencies"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-shell.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@npm-scanner/core": "workspace:*",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "open": "^10.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@npm-scanner/report-ui": "workspace:*",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
