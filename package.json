{
  "name": "lockhawk-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fast, free, accurate npm dependency vulnerability scanner — local + CI/CD, powered by OSV.dev",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "build:all": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck",
    "lint": "prettier --check . && pnpm run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pb": "node scripts/release.mjs",
    "test:release": "node --test 'scripts/*.test.mjs'"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "semver": "^7.6.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "tsup>esbuild": "^0.28.1"
    }
  }
}
